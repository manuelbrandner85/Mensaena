# ============================================================
# MENSAENA – Environment Variables
# ============================================================
# Kopiere diese Datei als .env.local und fülle alle Werte aus.
# NIEMALS .env.local in Git committen!

# ── Supabase ──────────────────────────────────────────────
# Aus deinem Supabase Dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Service Role Key – NUR server-seitig verwenden, nie im Client!
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Mensaena
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudflare (Optional für Turnstile Bot-Schutz) ───────
# NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
# CF_TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# ── PWA Push Notifications ────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# ── Routing / Isochrones (OpenRouteService) ──────────────
# Kostenloser API-Key unter https://openrouteservice.org/
# Für Routing, Erreichbarkeits-Analysen und Entfernungsanzeige
NEXT_PUBLIC_ORS_API_KEY=YOUR_ORS_API_KEY

# ── Deutsche Digitale Bibliothek (DDB) API ───────────────
# Kostenlos unter https://www.deutsche-digitale-bibliothek.de/user/apikey
# Für historische Fotos & Kulturgüter zur Region des Users
NEXT_PUBLIC_DDB_API_KEY=YOUR_DDB_API_KEY

# ── E-Mail (Optional via Supabase SMTP) ──────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password
