{
  "name": "mensaena",
  "version": "1.0.0-beta",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "cf:deploy": "npx wrangler pages deploy out --project-name mensaena",
    "android:setup": "bash scripts/setup-android.sh",
    "android:icons": "npx @capacitor/assets generate --iconPath assets/icon-only.png --splashPath assets/splash.png --android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "cd android && ./gradlew assembleDebug",
    "android:build:release": "cd android && ./gradlew assembleRelease",
    "android:rebuild": "npm run android:sync && npm run android:icons && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.4",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.400.0",
    "next": "15.3.0",
    "next-intl": "^4.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@opennextjs/cloudflare": "^1.6.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^8",
    "eslint-config-next": "15.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.79.0"
  }
