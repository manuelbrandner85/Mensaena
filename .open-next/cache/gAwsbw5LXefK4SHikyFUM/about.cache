{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"4294967294","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"}},"html":"<!DOCTYPE html><html lang=\"de\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/mensaena-logo.png\"/><link rel=\"stylesheet\" href=\"/_next/static/css/55693049b062c6a3.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/c4c2acad51691eba.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-efe1f821454c0298.js\"/><script src=\"/_next/static/chunks/4bd1b696-657a979e1cd53acb.js\" async=\"\"></script><script src=\"/_next/static/chunks/1684-583776c247aeef59.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-040212caff830a77.js\" async=\"\"></script><script src=\"/_next/static/chunks/6874-e889e1a85a449cc3.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/error-709bf343576024e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/3568-a2616a198649bdd9.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-5e604f091edf37a3.js\" async=\"\"></script><script src=\"/_next/static/chunks/7598-62e73530036a0011.js\" async=\"\"></script><script src=\"/_next/static/chunks/3063-32ba7ed543be127c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/about/page-39b87f7c6119c6f1.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/><title>Über uns – Mensaena</title><meta name=\"description\" content=\"Erfahre mehr über die Mensaena-Plattform und unsere Mission für Gemeinwohl und Nachhaltigkeit.\"/><meta name=\"keywords\" content=\"Gemeinwohl, Hilfe, Tauschen, Teilen, Gemeinschaft, lokal, nachhaltig\"/><meta property=\"og:title\" content=\"Mensaena – die Gemeinwohl Plattform\"/><meta property=\"og:description\" content=\"Menschen verbinden. Hilfe organisieren. Ressourcen teilen.\"/><meta property=\"og:locale\" content=\"de_DE\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Mensaena – die Gemeinwohl Plattform\"/><meta name=\"twitter:description\" content=\"Menschen verbinden. Hilfe organisieren. Ressourcen teilen.\"/><script>document.querySelectorAll('body link[rel=\"icon\"], body link[rel=\"apple-touch-icon\"]').forEach(el => document.head.appendChild(el))</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-background antialiased\"><main class=\"min-h-screen\"><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-center justify-between h-16 md:h-18\"><a class=\"flex items-center gap-0 group\" href=\"/\"><img alt=\"Mensaena Logo\" width=\"160\" height=\"107\" decoding=\"async\" data-nimg=\"1\" class=\"h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-200\" style=\"color:transparent\" src=\"/mensaena-logo.png\"/></a><nav class=\"hidden md:flex items-center gap-1\"><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#features\">Funktionen</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#how-it-works\">So funktioniert es</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#why-mensaena\">Warum Mensaena?</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"/about\">Über uns</a></nav><div class=\"hidden md:flex items-center gap-3\"><a class=\"btn-ghost text-sm px-4 py-2\" href=\"/login\">Anmelden</a><a class=\"btn-primary text-sm px-5 py-2.5\" href=\"/register\">Registrieren</a></div><button class=\"md:hidden p-2 rounded-lg text-gray-600 hover:bg-warm-100 transition-colors\" aria-label=\"Menü öffnen\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-5 h-5\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></div></header><section class=\"pt-32 pb-20 bg-gradient-to-b from-primary-50 to-white\"><div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\"><div class=\"inline-flex items-center gap-2 px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-4 h-4\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg> Über Mensaena</div><h1 class=\"text-4xl md:text-5xl font-bold text-gray-900 mb-6\">Freiheit beginnt im <span class=\"text-primary-600\">Bewusstsein</span></h1><p class=\"text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto\">Mensaena ist eine deutschsprachige Gemeinwohl-Plattform, die Menschen in ihrer Nachbarschaft vernetzt – lokal, persönlich und nachhaltig.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 mb-16\"><div class=\"card p-8\"><div class=\"w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-6 h-6 text-primary-600\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg></div><h2 class=\"text-xl font-bold text-gray-900 mb-3\">Unsere Mission</h2><p class=\"text-gray-600 leading-relaxed\">Wir glauben, dass echte Gemeinschaft und gegenseitige Hilfe die Grundlagen einer gesunden Gesellschaft sind. Mensaena schafft den digitalen Raum dafür – kostenlos, ohne Werbung und ohne Datenmissbrauch.</p></div><div class=\"card p-8\"><div class=\"w-12 h-12 bg-sage-100 rounded-xl flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users w-6 h-6 text-sage-600\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><h2 class=\"text-xl font-bold text-gray-900 mb-3\">Für alle</h2><p class=\"text-gray-600 leading-relaxed\">Mensaena richtet sich an Menschen, die aktiv ihre Nachbarschaft mitgestalten möchten – ob als Helfer, als Suchende, als Tier- oder Naturliebhaber, oder als Teil der lokalen Gemeinschaft.</p></div><div class=\"card p-8\"><div class=\"w-12 h-12 bg-trust-100 rounded-xl flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-6 h-6 text-trust-500\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div><h2 class=\"text-xl font-bold text-gray-900 mb-3\">Unsere Werte</h2><ul class=\"text-gray-600 space-y-2\"><li class=\"flex items-center gap-2\"><span class=\"w-1.5 h-1.5 bg-primary-400 rounded-full\"></span>Transparenz &amp; Vertrauen</li><li class=\"flex items-center gap-2\"><span class=\"w-1.5 h-1.5 bg-primary-400 rounded-full\"></span>Datenschutz first</li><li class=\"flex items-center gap-2\"><span class=\"w-1.5 h-1.5 bg-primary-400 rounded-full\"></span>Kostenlos für alle</li><li class=\"flex items-center gap-2\"><span class=\"w-1.5 h-1.5 bg-primary-400 rounded-full\"></span>Nachhaltig &amp; lokal</li></ul></div><div class=\"card p-8\"><div class=\"w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-6 h-6 text-green-600\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><h2 class=\"text-xl font-bold text-gray-900 mb-3\">Kontakt</h2><p class=\"text-gray-600 leading-relaxed mb-3\">Hast du Fragen, Feedback oder möchtest du mitmachen?</p><a href=\"mailto:hallo@mensaena.de\" class=\"text-primary-600 font-medium hover:underline\">hallo@mensaena.de</a></div></div><div class=\"text-center\"><a class=\"btn-primary text-base px-8 py-4 mr-4\" href=\"/register\">Jetzt kostenlos mitmachen</a><a class=\"btn-secondary text-base px-8 py-4\" href=\"/\">Zurück zur Startseite</a></div></div></section><footer class=\"bg-gray-900 text-gray-300\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10\"><div class=\"lg:col-span-1\"><a class=\"flex items-center gap-2.5 mb-4\" href=\"/\"><img alt=\"Mensaena\" loading=\"lazy\" width=\"160\" height=\"107\" decoding=\"async\" data-nimg=\"1\" class=\"h-12 w-auto object-contain brightness-0 invert\" style=\"color:transparent\" src=\"/mensaena-logo.png\"/></a><p class=\"text-sm text-gray-400 leading-relaxed mb-6\">Die Gemeinwohl-Plattform. Menschen verbinden, Hilfe organisieren, Ressourcen nachhaltig teilen – lokal und persönlich.</p><div class=\"flex items-center gap-2 text-sm text-gray-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-4 h-4 text-primary-500\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg><span>Made with care for the community</span></div></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Plattform</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"#features\">Funktionen</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"#how-it-works\">So funktioniert es</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/register\">Registrieren</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/login\">Anmelden</a></li></ul></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Bereiche</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/map\">Interaktive Karte</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/rescuer\">Retter-System</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/animals\">Tierbereich</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/housing\">Wohnen &amp; Alltag</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/community\">Community</a></li></ul></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Rechtliches</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/datenschutz\">Datenschutz</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/impressum\">Impressum</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/nutzungsbedingungen\">Nutzungsbedingungen</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/kontakt\">Kontakt</a></li></ul><div class=\"mt-6 p-3 bg-gray-800 rounded-xl\"><div class=\"flex items-center gap-2 mb-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail w-4 h-4 text-primary-500\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg><span class=\"text-xs font-medium text-white\">Kontakt</span></div><a href=\"mailto:hallo@mensaena.de\" class=\"text-xs text-gray-400 hover:text-primary-400 transition-colors\">hallo@mensaena.de</a></div></div></div><div class=\"border-t border-gray-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-4\"><p class=\"text-xs text-gray-500\">© 2026 Mensaena. Alle Rechte vorbehalten.</p><div class=\"flex items-center gap-4\"><a class=\"text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1\" href=\"/datenschutz\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-3 h-3\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg> Datenschutz</a><a class=\"text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1\" href=\"/impressum\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-file-text w-3 h-3\"><path d=\"M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z\"></path><path d=\"M14 2v4a2 2 0 0 0 2 2h4\"></path><path d=\"M10 9H8\"></path><path d=\"M16 13H8\"></path><path d=\"M16 17H8\"></path></svg> Impressum</a></div></div></div></footer></main><!--$--><!--/$--><!--$--><!--/$--><div data-rht-toaster=\"\" style=\"position:fixed;z-index:9999;top:16px;left:16px;right:16px;bottom:16px;pointer-events:none\"></div><script src=\"/_next/static/chunks/webpack-efe1f821454c0298.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[7555,[],\\\"\\\"]\\n3:I[1901,[\\\"6874\\\",\\\"static/chunks/6874-e889e1a85a449cc3.js\\\",\\\"8039\\\",\\\"static/chunks/app/error-709bf343576024e4.js\\\"],\\\"default\\\"]\\n4:I[1295,[],\\\"\\\"]\\n5:I[3568,[\\\"3568\\\",\\\"static/chunks/3568-a2616a198649bdd9.js\