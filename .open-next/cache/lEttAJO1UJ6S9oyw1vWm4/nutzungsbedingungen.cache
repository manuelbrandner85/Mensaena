":\"/mensaena-logo.png\",\"alt\":\"Mensaena\",\"width\":140,\"height\":94,\"className\":\"h-10 w-auto object-contain\"}]}],[\"$\",\"div\",null,{\"className\":\"card p-8\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-2xl font-bold text-gray-900 mb-6\",\"children\":\"Nutzungsbedingungen\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-gray-400 mb-6\",\"children\":\"Stand: April 2026\"}],[\"$\",\"div\",null,{\"className\":\"space-y-6 text-sm text-gray-700\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"1. Geltungsbereich\"}],[\"$\",\"p\",null,{\"children\":\"Diese Nutzungsbedingungen gelten für die Nutzung der Mensaena-Plattform (mensaena.de und mensaena.manuelbrandner4.workers.dev) und aller damit verbundenen Dienste. Mit der Registrierung akzeptierst du diese Bedingungen.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"2. Leistungsbeschreibung\"}],[\"$\",\"p\",null,{\"children\":\"Mensaena ist eine kostenlose Gemeinwohl-Plattform zur lokalen Vernetzung von Menschen. Die Plattform ermöglicht das Inserieren von Hilfsangeboten und -gesuchen, Community-Chats, Tierhilfe, regionale Versorgung, Krisenunterstützung und weitere Funktionen.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"3. Registrierung & Konto\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-1\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Die Registrierung ist ab 16 Jahren erlaubt.\"}],[\"$\",\"li\",null,{\"children\":\"Du bist für die Sicherheit deines Kontos selbst verantwortlich.\"}],[\"$\",\"li\",null,{\"children\":\"Jede Person darf nur ein Konto besitzen.\"}],[\"$\",\"li\",null,{\"children\":\"Falschangaben bei der Registrierung können zur Sperrung führen.\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"4. Verhaltensregeln\"}],[\"$\",\"p\",null,{\"className\":\"mb-2\",\"children\":\"Auf Mensaena ist Folgendes untersagt:\"}],[\"$\",\"ul\",null,{\"className\":\"list-disc pl-5 space-y-1\",\"children\":[[\"$\",\"li\",null,{\"children\":\"Hassrede, Diskriminierung oder Belästigung anderer Nutzer\"}],[\"$\",\"li\",null,{\"children\":\"Verbreitung von Falschinformationen oder Spam\"}],[\"$\",\"li\",null,{\"children\":\"Werbung für kommerzielle Zwecke ohne ausdrückliche Erlaubnis\"}],[\"$\",\"li\",null,{\"children\":\"Teilen von rechtswidrigen oder anstößigen Inhalten\"}],[\"$\",\"li\",null,{\"children\":\"Missbrauch des Krisensystems für nicht dringende Anfragen\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"5. Inhalte & Verantwortung\"}],[\"$\",\"p\",null,{\"children\":\"Nutzer sind selbst für die von ihnen erstellten Inhalte verantwortlich. Mensaena behält sich vor, Inhalte zu entfernen, die gegen diese Bedingungen verstoßen. Mensaena übernimmt keine Haftung für die Richtigkeit von Nutzerinhalten.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"6. Kostenlosigkeit\"}],[\"$\",\"p\",null,{\"children\":\"Die Nutzung von Mensaena ist und bleibt kostenlos. Es gibt keine versteckten Gebühren, keine Abonnements und keine Werbung. Mensaena finanziert sich über freiwillige Spenden und ehrenamtliches Engagement.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"7. Konto-Kündigung\"}],[\"$\",\"p\",null,{\"children\":\"Du kannst dein Konto jederzeit unter Einstellungen löschen. Mensaena kann Konten bei schwerwiegenden Verstößen gegen diese Bedingungen sperren oder löschen.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"8. Änderungen\"}],[\"$\",\"p\",null,{\"children\":\"Mensaena behält sich vor, diese Nutzungsbedingungen anzupassen. Wesentliche Änderungen werden den Nutzern rechtzeitig mitgeteilt.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-semibold text-gray-900 mb-2\",\"children\":\"9. Kontakt\"}],[\"$\",\"p\",null,{\"children\":[\"Bei Fragen zu diesen Nutzungsbedingungen wende dich an:\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hallo@mensaena.de\",\"className\":\"text-primary-600 hover:underline\",\"children\":\"hallo@mensaena.de\"}]]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"text-center mt-6 flex gap-4 justify-center\",\"children\":[[\"$\",\"$L6\",null,{\"href\":\"/datenschutz\",\"className\":\"text-sm text-gray-500 hover:text-gray-700 transition-colors\",\"children\":\"Datenschutzerklärung\"}],[\"$\",\"$L6\",null,{\"href\":\"/\",\"className\":\"text-sm text-gray-500 hover:text-gray-700 transition-colors\",\"children\":\"← Zurück zur Startseite\"}]]}]]}]}],[\"$\",\"$L8\",null,{\"children\":\"$L9\"}],null,[\"$\",\"$La\",null,{\"children\":[\"$Lb\",\"$Lc\",[\"$\",\"$Ld\",null,{\"promise\":\"$@e\"}]]}]]}],{},null,false]},null,false]},null,false],[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$1\",\"N85uLIsBoKbeI360cMVTB\",{\"children\":[[\"$\",\"$Lf\",null,{\"children\":\"$L10\"}],null]}],null]}],false]],\"m\":\"$undefined\",\"G\":[\"$11\",\"$undefined\"],\"s\":false,\"S\":true}\n12:\"$Sreact.suspense\"\n13:I[4911,[],\"AsyncMetadata\"]\n9:[\"$\",\"$12\",null,{\"fallback\":null,\"children\":[\"$\",\"$L13\",null,{\"promise\":\"$@14\"}]}]\nc:null\n10:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\nb:null\n14:{\"metadata\":[[\"$\",\"title\",\"0\",{\"children\":\"Nutzungsbedingungen – Mensaena\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Nutzungsbedingungen der Mensaen