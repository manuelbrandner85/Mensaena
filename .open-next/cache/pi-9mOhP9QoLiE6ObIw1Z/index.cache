{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"4294967294","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><html lang=\"de\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/mensaena-logo.png\"/><link rel=\"stylesheet\" href=\"/_next/static/css/55693049b062c6a3.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/css/36afe2eb13d9f2b6.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-efe1f821454c0298.js\"/><script src=\"/_next/static/chunks/4bd1b696-657a979e1cd53acb.js\" async=\"\"></script><script src=\"/_next/static/chunks/1684-583776c247aeef59.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-040212caff830a77.js\" async=\"\"></script><script src=\"/_next/static/chunks/6874-e889e1a85a449cc3.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/error-709bf343576024e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/3568-a2616a198649bdd9.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-5e604f091edf37a3.js\" async=\"\"></script><script src=\"/_next/static/chunks/7598-62e73530036a0011.js\" async=\"\"></script><script src=\"/_next/static/chunks/3063-32ba7ed543be127c.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-8d77cce0b587e3ce.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/><title>Mensaena – die Gemeinwohl Plattform</title><meta name=\"description\" content=\"Mensaena verbindet Menschen lokal, organisiert Hilfe, fördert nachhaltige Ressourcennutzung und stärkt das Gemeinwohl.\"/><meta name=\"keywords\" content=\"Gemeinwohl, Hilfe, Tauschen, Teilen, Gemeinschaft, lokal, nachhaltig\"/><meta property=\"og:title\" content=\"Mensaena – die Gemeinwohl Plattform\"/><meta property=\"og:description\" content=\"Menschen verbinden. Hilfe organisieren. Ressourcen teilen.\"/><meta property=\"og:locale\" content=\"de_DE\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Mensaena – die Gemeinwohl Plattform\"/><meta name=\"twitter:description\" content=\"Menschen verbinden. Hilfe organisieren. Ressourcen teilen.\"/><script>document.querySelectorAll('body link[rel=\"icon\"], body link[rel=\"apple-touch-icon\"]').forEach(el => document.head.appendChild(el))</script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-background antialiased\"><main class=\"min-h-screen\"><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex items-center justify-between h-16 md:h-18\"><a class=\"flex items-center gap-0 group\" href=\"/\"><img alt=\"Mensaena Logo\" width=\"160\" height=\"107\" decoding=\"async\" data-nimg=\"1\" class=\"h-12 w-auto object-contain group-hover:scale-105 transition-transform duration-200\" style=\"color:transparent\" src=\"/mensaena-logo.png\"/></a><nav class=\"hidden md:flex items-center gap-1\"><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#features\">Funktionen</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#how-it-works\">So funktioniert es</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"#why-mensaena\">Warum Mensaena?</a><a class=\"px-4 py-2 text-sm font-medium text-gray-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all duration-150\" href=\"/about\">Über uns</a></nav><div class=\"hidden md:flex items-center gap-3\"><a class=\"btn-ghost text-sm px-4 py-2\" href=\"/login\">Anmelden</a><a class=\"btn-primary text-sm px-5 py-2.5\" href=\"/register\">Registrieren</a></div><button class=\"md:hidden p-2 rounded-lg text-gray-600 hover:bg-warm-100 transition-colors\" aria-label=\"Menü öffnen\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-5 h-5\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></div></header><section class=\"relative min-h-screen flex items-center hero-gradient overflow-hidden pt-16\"><div class=\"absolute inset-0 overflow-hidden pointer-events-none\"><div class=\"absolute -top-40 -right-40 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl\"></div><div class=\"absolute -bottom-40 -left-40 w-96 h-96 bg-trust-100/40 rounded-full blur-3xl\"></div><div class=\"absolute top-1/3 left-1/2 w-64 h-64 bg-sage-200/20 rounded-full blur-2xl\"></div><div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image:radial-gradient(circle, #66BB6A 1px, transparent 1px);background-size:32px 32px\"></div></div><div class=\"relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20\"><div class=\"max-w-3xl mx-auto text-center\"><div class=\"inline-flex items-center gap-2 px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-8 border border-primary-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-4 h-4\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg>die Gemeinwohl Plattform</div><h1 class=\"text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 leading-tight text-balance mb-6\">Gemeinsam<!-- --> <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-800\">stärker</span> <!-- -->vor Ort.</h1><p class=\"text-xl md:text-2xl text-gray-600 leading-relaxed mb-10 text-balance\">Mensaena verbindet Menschen in deiner Nachbarschaft. Hilfe finden, Hilfe geben – nachhaltig, lokal und persönlich.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 mb-16\"><a class=\"btn-primary text-base px-8 py-4 w-full sm:w-auto\" href=\"/register\">Jetzt kostenlos registrieren<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-5 h-5\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a class=\"btn-secondary text-base px-8 py-4 w-full sm:w-auto\" href=\"/login\">Anmelden</a><a href=\"#features\" class=\"btn-ghost text-base px-6 py-4 text-gray-500 hover:text-gray-700\">Mehr erfahren ↓</a></div><div class=\"flex flex-wrap items-center justify-center gap-6 text-sm text-gray-500\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-4 h-4 text-primary-600\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg><span>100% kostenlos</span></div><div class=\"w-1 h-1 rounded-full bg-gray-300 hidden sm:block\"></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-4 h-4 text-primary-600\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span>Lokal &amp; persönlich</span></div><div class=\"w-1 h-1 rounded-full bg-gray-300 hidden sm:block\"></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users w-4 h-4 text-primary-600\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg><span>Echte Gemeinschaft</span></div><div class=\"w-1 h-1 rounded-full bg-gray-300 hidden sm:block\"></div><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-4 h-4 text-primary-600\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg><span>Nachhaltig</span></div></div></div><div class=\"mt-20 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto\"><div class=\"p-4 rounded-2xl border bg-red-50 border-red-100 transition-all duration-200 hover:-translate-y-1 hover:shadow-md\n        shadow-card\"><div class=\"flex items-start gap-3\"><span class=\"text-2xl\">🆘</span><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-red-400 flex-shrink-0\"></span><span class=\"text-xs font-semibold text-gray-800\">Hilfe gesucht</span></div><p class=\"text-xs text-gray-600 leading-relaxed line-clamp-2\">Nachbarin sucht Begleitung zum Arzt</p><p class=\"text-xs text-gray-400 mt-2\">vor 5 Min.</p></div></div></div><div class=\"p-4 rounded-2xl border bg-primary-50 border-primary-100 transition-all duration-200 hover:-translate-y-1 hover:shadow-md\n        sm:-translate-y-3 shadow-hover ring-2 ring-primary-200\"><div class=\"flex items-start gap-3\"><span class=\"text-2xl\">🌿</span><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-primary-400 flex-shrink-0\"></span><span class=\"text-xs font-semibold text-gray-800\">Gemüse verschenken</span></div><p class=\"text-xs text-gray-600 leading-relaxed line-clamp-2\">Frische Zucchini aus dem Garten – kostenlos abholen</p><p class=\"text-xs text-gray-400 mt-2\">vor 12 Min.</p></div></div></div><div class=\"p-4 rounded-2xl border bg-trust-50 border-trust-100 transition-all duration-200 hover:-translate-y-1 hover:shadow-md\n        shadow-card\"><div class=\"flex items-start gap-3\"><span class=\"text-2xl\">🐕</span><div class=\"flex-1 min-w-0\"><div class=\"flex items-center gap-2 mb-1\"><span class=\"w-2 h-2 rounded-full bg-trust-300 flex-shrink-0\"></span><span class=\"text-xs font-semibold text-gray-800\">Gassi-Hilfe</span></div><p class=\"text-xs text-gray-600 leading-relaxed line-clamp-2\">Suche jemanden für Hundespaziergänge diese Woche</p><p class=\"text-xs text-gray-400 mt-2\">vor 28 Min.</p></div></div></div></div></div></section><section id=\"features\" class=\"py-24 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4\">Was Mensaena kann</div><h2 class=\"section-title\">Alle wichtigen Funktionen auf<!-- --> <span class=\"text-primary-600\">einem Blick</span></h2><p class=\"section-subtitle\">Mensaena bündelt alle Werkzeuge für ein aktives, vernetztes und nachhaltiges Miteinander in einer übersichtlichen Plattform.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-primary-100 text-primary-700 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users w-6 h-6\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Hilfe organisieren</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Suche oder biete konkrete Hilfe in deiner Nachbarschaft. Von Arztbegleitung bis Umzugshilfe – direkt und unkompliziert.</p></div><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-sage-100 text-sage-500 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-recycle w-6 h-6\"><path d=\"M7 19H4.815a1.83 1.83 0 0 1-1.57-.881 1.785 1.785 0 0 1-.004-1.784L7.196 9.5\"></path><path d=\"M11 19h8.203a1.83 1.83 0 0 0 1.556-.89 1.784 1.784 0 0 0 0-1.775l-1.226-2.12\"></path><path d=\"m14 16-3 3 3 3\"></path><path d=\"M8.293 13.596 7.196 9.5 3.1 10.598\"></path><path d=\"m9.344 5.811 1.093-1.892A1.83 1.83 0 0 1 11.985 3a1.784 1.784 0 0 1 1.546.888l3.943 6.843\"></path><path d=\"m13.378 9.633 4.096 1.098 1.097-4.096\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Ressourcen teilen</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Verschenke, tausche oder verleihe Dinge. Gemeinsam nutzen statt wegwerfen – nachhaltig und sinnvoll.</p></div><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-trust-100 text-trust-400 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-6 h-6\"><path d=\"M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Lokale Angebote finden</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Die interaktive Karte zeigt alle Angebote und Anfragen in deiner Umgebung. Filtere nach Kategorie und Entfernung.</p></div><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-green-100 text-green-700 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-6 h-6\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Nachhaltige Unterstützung</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Regionale Produkte, Erntehilfe, Selbstversorgung – Mensaena fördert eine nachhaltige, gemeinschaftliche Lebensweise.</p></div><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-blue-100 text-blue-700 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-6 h-6\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Vertrauensvolles Profil</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Baue dein Vertrauens-Profil auf. Bewertungen, Fähigkeiten und Erfahrungen machen Interaktionen sicherer.</p></div><div class=\"group card p-6 hover:shadow-hover hover:-translate-y-0.5 transition-all duration-200 cursor-pointer\"><div class=\"w-12 h-12 rounded-xl bg-purple-100 text-purple-700 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle w-6 h-6\"><path d=\"M7.9 20A9 9 0 1 0 4 16.1L2 22Z\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 mb-2\">Direkte Kommunikation</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Schreibe direkte Nachrichten, nutze Gruppenchats oder kontaktiere Nutzer per WhatsApp und Telefon.</p></div></div></div></section><section id=\"why-mensaena\" class=\"py-24 section-gradient-alt\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-warm-200 text-gray-700 rounded-full text-sm font-medium mb-4\">Warum Mensaena?</div><h2 class=\"section-title\">Eine Plattform, der du<!-- --> <span class=\"text-primary-600\">wirklich vertrauen</span> kannst</h2><p class=\"section-subtitle\">Mensaena wurde mit einem klaren Ziel entwickelt: Menschen zusammenbringen, ohne Ablenkung, ohne Lärm, ohne Kommerz.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"p-6 rounded-2xl bg-gradient-to-br from-trust-50 to-trust-100/50 border border-trust-200 hover:shadow-card transition-all duration-200\"><div class=\"flex items-start gap-4\"><span class=\"text-3xl\">🛡️</span><div><h3 class=\"text-lg font-semibold text-gray-900 mb-3\">Vertrauenswürdig</h3><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Verifizierte Profile mit Bewertungssystem</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Transparente Nutzungshistorie</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Community-basiertes Vertrauen</li></ul></div></div></div><div class=\"p-6 rounded-2xl bg-gradient-to-br from-primary-50 to-sage-50 border border-primary-200 hover:shadow-card transition-all duration-200\"><div class=\"flex items-start gap-4\"><span class=\"text-3xl\">✨</span><div><h3 class=\"text-lg font-semibold text-gray-900 mb-3\">Einfach &amp; übersichtlich</h3><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Intuitive Navigation ohne Lernkurve</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Klare Kategorien und Filter</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Moderne, aufgeräumte Oberfläche</li></ul></div></div></div><div class=\"p-6 rounded-2xl bg-gradient-to-br from-warm-100 to-warm-50 border border-warm-300 hover:shadow-card transition-all duration-200\"><div class=\"flex items-start gap-4\"><span class=\"text-3xl\">📍</span><div><h3 class=\"text-lg font-semibold text-gray-900 mb-3\">Lokal &amp; persönlich</h3><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Interaktive Karte für deine Region</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Ortsbezogene Suche und Angebote</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Direkte Kontaktmöglichkeiten</li></ul></div></div></div><div class=\"p-6 rounded-2xl bg-gradient-to-br from-green-50 to-primary-50 border border-green-200 hover:shadow-card transition-all duration-200\"><div class=\"flex items-start gap-4\"><span class=\"text-3xl\">🌱</span><div><h3 class=\"text-lg font-semibold text-gray-900 mb-3\">Soziale Wirkung</h3><ul class=\"space-y-2\"><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Sichtbare Impact-Scores</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Community-Projekte und Abstimmungen</li><li class=\"flex items-center gap-2 text-sm text-gray-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-primary-600 flex-shrink-0\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Positiver Beitrag für die Gesellschaft</li></ul></div></div></div></div><div class=\"mt-16 grid grid-cols-2 md:grid-cols-4 gap-6\"><div class=\"text-center p-5 bg-white rounded-2xl shadow-soft border border-warm-100\"><div class=\"text-2xl md:text-3xl font-bold text-primary-600 mb-1\">100%</div><div class=\"text-sm font-semibold text-gray-800\">Kostenlos</div><div class=\"text-xs text-gray-500 mt-0.5\">für alle Nutzer</div></div><div class=\"text-center p-5 bg-white rounded-2xl shadow-soft border border-warm-100\"><div class=\"text-2xl md:text-3xl font-bold text-primary-600 mb-1\">16+</div><div class=\"text-sm font-semibold text-gray-800\">Bereiche</div><div class=\"text-xs text-gray-500 mt-0.5\">in einer Plattform</div></div><div class=\"text-center p-5 bg-white rounded-2xl shadow-soft border border-warm-100\"><div class=\"text-2xl md:text-3xl font-bold text-primary-600 mb-1\">🗺️</div><div class=\"text-sm font-semibold text-gray-800\">Interaktive Karte</div><div class=\"text-xs text-gray-500 mt-0.5\">als Herzstück</div></div><div class=\"text-center p-5 bg-white rounded-2xl shadow-soft border border-warm-100\"><div class=\"text-2xl md:text-3xl font-bold text-primary-600 mb-1\">0€</div><div class=\"text-sm font-semibold text-gray-800\">Keine Werbung</div><div class=\"text-xs text-gray-500 mt-0.5\">kein Kommerz</div></div></div></div></section><section id=\"how-it-works\" class=\"py-24 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-2xl mx-auto mb-16\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4\">So einfach geht es</div><h2 class=\"section-title\">In 4 Schritten zur<!-- --> <span class=\"text-primary-600\">aktiven Gemeinschaft</span></h2><p class=\"section-subtitle\">Mensaena ist bewusst einfach gehalten. Kein Kompliziertes Setup, keine langen Lernphasen.</p></div><div class=\"relative\"><div class=\"absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-primary-200 via-primary-400 to-green-300 hidden lg:block\"></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\"><div class=\"relative text-center\"><div class=\"flex flex-col items-center mb-5\"><div class=\"relative\"><div class=\"w-16 h-16 rounded-2xl bg-primary-100 text-primary-700 flex items-center justify-center shadow-soft relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user-plus w-6 h-6\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><line x1=\"19\" x2=\"19\" y1=\"8\" y2=\"14\"></line><line x1=\"22\" x2=\"16\" y1=\"11\" y2=\"11\"></line></svg></div><span class=\"absolute -top-2 -right-2 w-6 h-6 bg-primary-600 text-white text-xs font-bold rounded-full flex items-center justify-center z-20\">01</span></div></div><h3 class=\"text-base font-semibold text-gray-900 mb-2\">Registrieren</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Erstelle deinen kostenlosen Account in weniger als 2 Minuten. Keine Kreditkarte, kein Abo.</p></div><div class=\"relative text-center\"><div class=\"flex flex-col items-center mb-5\"><div class=\"relative\"><div class=\"w-16 h-16 rounded-2xl bg-trust-100 text-trust-400 flex items-center justify-center shadow-soft relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-file-pen w-6 h-6\"><path d=\"M12.5 22H18a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v9.5\"></path><path d=\"M14 2v4a2 2 0 0 0 2 2h4\"></path><path d=\"M13.378 15.626a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z\"></path></svg></div><span class=\"absolute -top-2 -right-2 w-6 h-6 bg-primary-600 text-white text-xs font-bold rounded-full flex items-center justify-center z-20\">02</span></div></div><h3 class=\"text-base font-semibold text-gray-900 mb-2\">Profil anlegen</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Füge deinen Standort, deine Fähigkeiten und Interessen hinzu, damit andere dich finden können.</p></div><div class=\"relative text-center\"><div class=\"flex flex-col items-center mb-5\"><div class=\"relative\"><div class=\"w-16 h-16 rounded-2xl bg-warm-200 text-amber-700 flex items-center justify-center shadow-soft relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-search w-6 h-6\"><circle cx=\"11\" cy=\"11\" r=\"8\"></circle><path d=\"m21 21-4.3-4.3\"></path></svg></div><span class=\"absolute -top-2 -right-2 w-6 h-6 bg-primary-600 text-white text-xs font-bold rounded-full flex items-center justify-center z-20\">03</span></div></div><h3 class=\"text-base font-semibold text-gray-900 mb-2\">Inhalte entdecken</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Durchsuche die interaktive Karte, finde Hilfe-Angebote oder erstelle deinen eigenen Beitrag.</p></div><div class=\"relative text-center\"><div class=\"flex flex-col items-center mb-5\"><div class=\"relative\"><div class=\"w-16 h-16 rounded-2xl bg-green-100 text-green-700 flex items-center justify-center shadow-soft relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-zap w-6 h-6\"><path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg></div><span class=\"absolute -top-2 -right-2 w-6 h-6 bg-primary-600 text-white text-xs font-bold rounded-full flex items-center justify-center z-20\">04</span></div></div><h3 class=\"text-base font-semibold text-gray-900 mb-2\">Aktiv werden</h3><p class=\"text-sm text-gray-600 leading-relaxed\">Schreibe Nachrichten, helf anderen, teile Ressourcen und gestalte deine Gemeinschaft aktiv mit.</p></div></div></div></div></section><section class=\"py-24 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4\">Alle Bereiche</div><h2 class=\"section-title\">16 Bereiche für<!-- --> <span class=\"text-primary-600\">jede Lebenssituation</span></h2><p class=\"section-subtitle\">Von Alltagshilfe bis Krisenunterstützung – Mensaena bietet für jeden Bedarf den richtigen Bereich.</p></div><div class=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4\"><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🗺️</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Interaktive Karte</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Alle Angebote &amp; Anfragen in deiner Umgebung auf einen Blick</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🆘</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Retter-System</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Lebensmittel, Kleidung und mehr retten und verteilen</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🐾</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Tierbereich</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Tierheime, Vermittlung, Gassi-Hilfe und Tierhilfe</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🏡</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Wohnen &amp; Alltag</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Wohnungssuche, Notunterkünfte und Haushaltshilfe</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🌾</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Regionale Versorgung</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Bauernhöfe, regionale Produkte und Erntehilfe</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🧠</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Bildung &amp; Wissen</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Guides, Tutorials und Community-Wissen teilen</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🧘</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Mentale Unterstützung</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Gesprächspartner, anonyme Hilfe und lokale Treffen</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🛠️</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Skill-Netzwerk</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Fähigkeiten anbieten, lernen und voneinander profitieren</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🚗</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Mobilität</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Mitfahrgelegenheiten und Transporthilfe koordinieren</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🧺</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Teilen &amp; Tauschen</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Geräte, Kleidung und Bücher tauschen oder verschenken</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">📢</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Community</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Lokale Abstimmungen, Projekte und gemeinsame Lösungen</p></div><div class=\"group p-4 rounded-2xl bg-warm-50 border border-warm-100 hover:bg-primary-50 hover:border-primary-200 transition-all duration-200 cursor-pointer text-center hover:-translate-y-0.5 hover:shadow-card\"><div class=\"text-3xl mb-2 group-hover:scale-110 transition-transform duration-200\">🚑</div><h3 class=\"text-xs font-semibold text-gray-900 mb-1 leading-tight\">Krisensystem</h3><p class=\"text-xs text-gray-500 leading-relaxed hidden sm:block\">Schnelle Hilfe im Notfall – direkt und koordiniert</p></div></div></div></section><section class=\"py-24 bg-gradient-to-br from-primary-700 via-primary-600 to-primary-800 relative overflow-hidden\"><div class=\"absolute inset-0 overflow-hidden pointer-events-none\"><div class=\"absolute -top-20 -right-20 w-64 h-64 bg-white/5 rounded-full blur-2xl\"></div><div class=\"absolute -bottom-20 -left-20 w-64 h-64 bg-white/5 rounded-full blur-2xl\"></div><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl\"></div></div><div class=\"relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center\"><div class=\"inline-flex items-center justify-center w-16 h-16 bg-white/20 backdrop-blur rounded-2xl mb-8\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-8 h-8 text-white\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><h2 class=\"text-4xl md:text-5xl font-bold text-white mb-6 text-balance\">Werde Teil der Gemeinschaft</h2><p class=\"text-xl text-primary-100 leading-relaxed mb-10 text-balance max-w-2xl mx-auto\">Mensaena ist kostenlos, werbefrein und für alle. Registriere dich heute und beginne, deine Nachbarschaft aktiv mitzugestalten.</p><div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\"><a class=\"inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-primary-700 font-bold text-base rounded-xl hover:bg-primary-50 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5 w-full sm:w-auto\" href=\"/register\">Kostenlos registrieren<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-5 h-5\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a class=\"inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent text-white font-semibold text-base rounded-xl border-2 border-white/40 hover:border-white/70 hover:bg-white/10 transition-all duration-200 w-full sm:w-auto\" href=\"/login\">Bereits registriert? Anmelden</a></div><p class=\"mt-10 text-primary-200 text-sm\">✓ Keine Kreditkarte  ·  ✓ Keine versteckten Kosten  ·  ✓ Jederzeit kündbar</p></div></section><footer class=\"bg-gray-900 text-gray-300\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10\"><div class=\"lg:col-span-1\"><a class=\"flex items-center gap-2.5 mb-4\" href=\"/\"><img alt=\"Mensaena\" loading=\"lazy\" width=\"160\" height=\"107\" decoding=\"async\" data-nimg=\"1\" class=\"h-12 w-auto object-contain brightness-0 invert\" style=\"color:transparent\" src=\"/mensaena-logo.png\"/></a><p class=\"text-sm text-gray-400 leading-relaxed mb-6\">Die Gemeinwohl-Plattform. Menschen verbinden, Hilfe organisieren, Ressourcen nachhaltig teilen – lokal und persönlich.</p><div class=\"flex items-center gap-2 text-sm text-gray-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-4 h-4 text-primary-500\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg><span>Made with care for the community</span></div></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Plattform</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"#features\">Funktionen</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"#how-it-works\">So funktioniert es</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/register\">Registrieren</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/login\">Anmelden</a></li></ul></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Bereiche</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/map\">Interaktive Karte</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/rescuer\">Retter-System</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/animals\">Tierbereich</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/housing\">Wohnen &amp; Alltag</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/dashboard/community\">Community</a></li></ul></div><div><h3 class=\"text-white font-semibold text-sm uppercase tracking-wider mb-4\">Rechtliches</h3><ul class=\"space-y-3\"><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/datenschutz\">Datenschutz</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/impressum\">Impressum</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/nutzungsbedingungen\">Nutzungsbedingungen</a></li><li><a class=\"text-sm text-gray-400 hover:text-primary-400 transition-colors\" href=\"/kontakt\">Kontakt</a></li></ul><div class=\"mt-6 p-3 bg-gray-800 rounded-xl\"><div class=\"flex items-center gap-2 mb-1\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail w-4 h-4 text-primary-500\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg><span class=\"text-xs font-medium text-white\">Kontakt</span></div><a href=\"mailto:hallo@mensaena.de\" class=\"text-xs text-gray-400 hover:text-primary-400 transition-colors\">hallo@mensaena.de</a></div></div></div><div class=\"border-t border-gray-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-4\"><p class=\"text-xs text-gray-500\">© 2026 Mensaena. Alle Rechte vorbehalten.</p><div class=\"flex items-center gap-4\"><a class=\"text-xs text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1\" href=\"/datenschutz\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stro